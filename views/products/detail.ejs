<%- include('../partials/header') %>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h3 class="fw-bold mb-4">Detail Product</h3>

          <table class="table table-borderless align-middle mb-4">
            <tbody>
              <tr class="border-bottom">
                <td class="text-muted fw-semibold small py-3" style="width: 160px;">ID Product</td>
                <td class="text-dark py-3"><%= product.id %></td>
              </tr>
              <tr class="border-bottom">
                <td class="text-muted fw-semibold small py-3">Nama Product</td>
                <td class="text-dark fw-bold py-3"><%= product.name %></td>
              </tr>
              <tr class="border-bottom">
                <td class="text-muted fw-semibold small py-3">Category</td>
                <td class="py-3">
                  <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-1">
                    <%= product.category ? product.category.name : '-' %>
                  </span>
                </td>
              </tr>
              <tr class="border-bottom">
                <td class="text-muted fw-semibold small py-3">Harga</td>
                <td class="text-dark fw-bold py-3">Rp <%= Number(product.price).toLocaleString('id-ID') %></td>
              </tr>
              <tr class="border-bottom">
                <td class="text-muted fw-semibold small py-3">Stok</td>
                <td class="text-dark py-3"><%= product.stock %></td>
              </tr>
              <tr class="border-bottom">
                <td class="text-muted fw-semibold small py-3">Deskripsi</td>
                <td class="text-dark py-3"><%= product.description || '-' %></td>
              </tr>
              <tr class="border-bottom">
                <td class="text-muted fw-semibold small py-3">Dibuat Pada</td>
                <td class="text-dark small py-3"><%= new Date(product.created_at).toLocaleString('id-ID') %></td>
              </tr>
              <tr class="border-bottom">
                <td class="text-muted fw-semibold small py-3">Terakhir Diupdate</td>
                <td class="text-dark small py-3"><%= new Date(product.updated_at).toLocaleString('id-ID') %></td>
              </tr>
            </tbody>
          </table>

          <div class="d-flex gap-2">
            <a href="/products/<%= product.id %>/edit" class="btn btn-warning text-white px-4">Edit Product</a>
            <a href="/products" class="btn btn-outline-secondary px-4">Kembali</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

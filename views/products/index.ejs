<%- include('../partials/header') %>

<div class="container">
  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">Daftar Product</h2>
        <a href="/products/create" class="btn btn-primary">Tambah Product</a>
      </div>

      <!-- Form Pencarian -->
      <form action="/products" method="GET" class="row g-2 mb-4">
        <div class="col-md-9">
          <input type="text" name="search" class="form-control" placeholder="Cari product..." value="<%= search %>">
        </div>
        <div class="col-md-3 d-flex gap-2">
          <button type="submit" class="btn btn-primary flex-grow-1">Cari</button>
          <% if (search) { %>
            <a href="/products" class="btn btn-secondary">Reset</a>
          <% } %>
        </div>
      </form>

      <% if (products.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light text-uppercase small">
              <tr>
                <th style="width: 80px;">No</th>
                <th>Nama</th>
                <th>Category</th>
                <th>Harga</th>
                <th>Stok</th>
                <th style="width: 220px;" class="text-center">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% products.forEach(function(prod, index) { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><strong class="text-dark"><%= prod.name %></strong></td>
                  <td>
                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1 small">
                      <%= prod.category ? prod.category.name : '-' %>
                    </span>
                  </td>
                  <td>Rp <%= Number(prod.price).toLocaleString('id-ID') %></td>
                  <td>
                    <% if (prod.stock > 10) { %>
                      <span class="text-success fw-bold"><%= prod.stock %></span>
                    <% } else if (prod.stock > 0) { %>
                      <span class="text-warning fw-bold"><%= prod.stock %> (Menipis)</span>
                    <% } else { %>
                      <span class="text-danger fw-bold">Habis</span>
                    <% } %>
                  </td>
                  <td class="text-center">
                    <div class="d-flex justify-content-center gap-2">
                      <a href="/products/<%= prod.id %>" class="btn btn-primary btn-sm">Detail</a>
                      <a href="/products/<%= prod.id %>/edit" class="btn btn-warning btn-sm text-white">Edit</a>
                      <form action="/products/<%= prod.id %>/delete" method="POST" onsubmit="return confirm('Yakin hapus product ini?')">
                        <button type="submit" class="btn btn-danger btn-sm">Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="text-center py-5 text-muted">
          <p class="mb-0">Belum ada data product</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

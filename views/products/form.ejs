<%- include('../partials/header') %>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h3 class="fw-bold mb-4"><%= product ? 'Edit Product' : 'Tambah Product' %></h3>

          <form action="<%= product ? '/products/' + product.id + '/update' : '/products' %>" method="POST">
            <div class="mb-3">
              <label for="name" class="form-label fw-semibold small">Nama Product</label>
              <input type="text" id="name" name="name" class="form-control" placeholder="Masukkan nama product" 
                     value="<%= product ? product.name : '' %>" required>
            </div>

            <div class="mb-3">
              <label for="description" class="form-label fw-semibold small">Deskripsi</label>
              <textarea id="description" name="description" class="form-control" rows="3" placeholder="Masukkan deskripsi (opsional)"><%= product ? product.description || '' : '' %></textarea>
            </div>

            <div class="row mb-3">
              <div class="col">
                <label for="price" class="form-label fw-semibold small">Harga (Rp)</label>
                <input type="number" id="price" name="price" class="form-control" placeholder="Masukkan harga" 
                       value="<%= product ? product.price : '' %>" required min="0">
              </div>
              <div class="col">
                <label for="stock" class="form-label fw-semibold small">Stok</label>
                <input type="number" id="stock" name="stock" class="form-control" placeholder="Masukkan jumlah stok" 
                       value="<%= product ? product.stock : '' %>" required min="0">
              </div>
            </div>

            <div class="mb-4">
              <label for="category_id" class="form-label fw-semibold small">Category</label>
              <select id="category_id" name="category_id" class="form-select" required>
                <option value="">-- Pilih Category --</option>
                <% categories.forEach(function(cat) { %>
                  <option value="<%= cat.id %>" <%= product && product.category_id == cat.id ? 'selected' : '' %>>
                    <%= cat.name %>
                  </option>
                <% }); %>
              </select>
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary px-4"><%= product ? 'Update' : 'Simpan' %></button>
              <a href="/products" class="btn btn-outline-secondary px-4">Batal</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

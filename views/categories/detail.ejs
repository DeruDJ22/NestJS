<%- include('../partials/header') %>

<div class="container">
  <div class="row g-4">
    <!-- Card Detail Category -->
    <div class="col-md-4">
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-4">Detail Category</h4>

          <div class="mb-3 border-bottom pb-2">
            <span class="text-muted small fw-semibold d-block">ID</span>
            <span class="text-dark"><%= category.id %></span>
          </div>

          <div class="mb-3 border-bottom pb-2">
            <span class="text-muted small fw-semibold d-block">Nama Category</span>
            <span class="text-dark fw-bold"><%= category.name %></span>
          </div>

          <div class="mb-3 border-bottom pb-2">
            <span class="text-muted small fw-semibold d-block">Deskripsi</span>
            <span class="text-dark"><%= category.description || '-' %></span>
          </div>

          <div class="mb-3 border-bottom pb-2">
            <span class="text-muted small fw-semibold d-block">Dibuat Pada</span>
            <span class="text-dark small"><%= new Date(category.created_at).toLocaleString('id-ID') %></span>
          </div>

          <div class="mb-4 border-bottom pb-2">
            <span class="text-muted small fw-semibold d-block">Terakhir Diupdate</span>
            <span class="text-dark small"><%= new Date(category.updated_at).toLocaleString('id-ID') %></span>
          </div>

          <div class="d-grid gap-2">
            <a href="/categories/<%= category.id %>/edit" class="btn btn-warning text-white">Edit Category</a>
            <a href="/categories" class="btn btn-outline-secondary">Kembali ke Daftar</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Daftar Product -->
    <div class="col-md-8">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-4">Products dalam Category ini (<%= category.products ? category.products.length : 0 %>)</h4>

          <% if (category.products && category.products.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead class="table-light text-uppercase small">
                  <tr>
                    <th style="width: 80px;">No</th>
                    <th>Nama Product</th>
                    <th>Harga</th>
                    <th>Stok</th>
                    <th style="width: 120px;" class="text-center">Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  <% category.products.forEach(function(prod, index) { %>
                    <tr>
                      <td><%= index + 1 %></td>
                      <td><strong><%= prod.name %></strong></td>
                      <td>Rp <%= Number(prod.price).toLocaleString('id-ID') %></td>
                      <td><%= prod.stock %></td>
                      <td class="text-center">
                        <a href="/products/<%= prod.id %>" class="btn btn-primary btn-sm">Detail</a>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% else { %>
            <div class="text-center py-5 text-muted">
              <p class="mb-0">Belum ada product dalam category ini</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

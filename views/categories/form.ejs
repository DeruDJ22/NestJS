<%- include('../partials/header') %>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h3 class="fw-bold mb-4"><%= category ? 'Edit Category' : 'Tambah Category' %></h3>

          <form action="<%= category ? '/categories/' + category.id + '/update' : '/categories' %>" method="POST">
            <div class="mb-3">
              <label for="name" class="form-label fw-semibold small">Nama Category</label>
              <input type="text" id="name" name="name" class="form-control" placeholder="Masukkan nama category" 
                     value="<%= category ? category.name : '' %>" required>
            </div>

            <div class="mb-4">
              <label for="description" class="form-label fw-semibold small">Deskripsi</label>
              <textarea id="description" name="description" class="form-control" rows="3" placeholder="Masukkan deskripsi (opsional)"><%= category ? category.description || '' : '' %></textarea>
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary px-4"><%= category ? 'Update' : 'Simpan' %></button>
              <a href="/categories" class="btn btn-outline-secondary px-4">Batal</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

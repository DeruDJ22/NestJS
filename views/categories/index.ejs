<%- include('../partials/header') %>

<div class="container">
  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">Daftar Category</h2>
        <a href="/categories/create" class="btn btn-primary">Tambah Category</a>
      </div>

      <!-- Form Pencarian -->
      <form action="/categories" method="GET" class="row g-2 mb-4">
        <div class="col-md-9">
          <input type="text" name="search" class="form-control" placeholder="Cari category..." value="<%= search %>">
        </div>
        <div class="col-md-3 d-flex gap-2">
          <button type="submit" class="btn btn-primary flex-grow-1">Cari</button>
          <% if (search) { %>
            <a href="/categories" class="btn btn-secondary">Reset</a>
          <% } %>
        </div>
      </form>

      <% if (categories.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light text-uppercase small">
              <tr>
                <th style="width: 80px;">No</th>
                <th>Nama</th>
                <th>Deskripsi</th>
                <th>Dibuat</th>
                <th style="width: 220px;" class="text-center">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% categories.forEach(function(cat, index) { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><strong class="text-dark"><%= cat.name %></strong></td>
                  <td><%= cat.description || '-' %></td>
                  <td class="text-muted small"><%= new Date(cat.created_at).toLocaleDateString('id-ID') %></td>
                  <td class="text-center">
                    <div class="d-flex justify-content-center gap-2">
                      <a href="/categories/<%= cat.id %>" class="btn btn-primary btn-sm">Detail</a>
                      <a href="/categories/<%= cat.id %>/edit" class="btn btn-warning btn-sm text-white">Edit</a>
                      <form action="/categories/<%= cat.id %>/delete" method="POST" onsubmit="return confirm('Yakin hapus category ini?')">
                        <button type="submit" class="btn btn-danger btn-sm">Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="text-center py-5 text-muted">
          <p class="mb-0">Belum ada data category</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

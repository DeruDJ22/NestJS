<!-- error.ejs - Halaman Error -->
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error <%= statusCode %> - Admin Panel</title>
  <!-- Bootstrap 5 CSS CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center min-vh-100">
  <div class="container text-center">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 py-4">
          <div class="card-body">
            <h1 class="display-1 fw-bold text-danger mb-3"><%= statusCode %></h1>
            <h4 class="fw-semibold text-dark mb-3">Terjadi Kesalahan</h4>
            <p class="text-muted mb-4"><%= message %></p>
            <a href="/dashboard" class="btn btn-primary btn-lg px-4">Kembali ke Dashboard</a>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Bootstrap 5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
